OMNIGENT_SLACK_BOT_TOKEN=xoxb-your-bot-token
OMNIGENT_SLACK_APP_TOKEN=xapp-your-app-level-token
OMNIGENT_SERVER_URL=https://omnigent.example.com

# Optional but strongly recommended: shared secret from Omnigent server
# Set it to the SAME value as the Omnigent server's
# OMNIGENT_DEVICE_CLIENT_SECRET; the bot then sends it on the device
# authorize/token/revoke calls (X-Omnigent-Client-Secret header) so the
# server only accepts this client. Leave unset when the server doesn't
# require it. Only meaningful in accounts mode (the OIDC flow doesn't use it).
# OMNIGENT_DEVICE_CLIENT_SECRET=

# The bot auto-detects the server's auth mode (via GET /v1/me, like
# the `omnigent login` CLI) and picks the matching login flow — no auth-mode
# config here:
#   • accounts → OAuth 2.0 device grant (a consent page in the browser).
#                Requires the Omnigent server to have the device grant enabled
#                (OMNIGENT_DEVICE_GRANT_ENABLED=1 on the server — it is
#                default-off), otherwise accounts-mode login can't complete.
#   • oidc     → the server's cli-login ticket flow (the user signs in at your
#                IdP; no device grant, no refresh token)
#   • header   → unsupported
# The Omnigent server's own OMNIGENT_OIDC_* / OMNIGENT_AUTH_* env vars decide
# its mode; the bot needs none of them.
#
# A Fernet key that encrypts each user's delegated token at rest so a stolen
# database file can't impersonate them — generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, tokens are kept in memory only (never written to disk) and lost on
# restart, so users re-authenticate; the integration still works.
# OMNIGENT_SLACK_TOKEN_ENCRYPTION_KEY=

# Optional runtime tuning
# LOG_LEVEL=INFO
# Where the bot's SQLite store lives. Defaults to
# $OMNIGENT_DATA_DIR/omnigent_slack.sqlite3 (or ~/.omnigent/omnigent_slack.sqlite3
# when OMNIGENT_DATA_DIR is unset). Set this to override.
# OMNIGENT_SLACK_DATABASE_PATH=
